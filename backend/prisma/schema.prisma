generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  TEAM_MEMBER
}

enum BillingFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum ClientStatus {
  ACTIVE
  PAUSED
  CANCELLED
  PENDING
  ONE_TIME
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  CASH
  CHECK
  PAYPAL
  OTHER
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum ExpenseCategory {
  RENT
  SALARIES
  SOFTWARE_SUBSCRIPTIONS
  INSURANCE
  ADS_SPEND
  FREELANCERS
  EQUIPMENT
  TRAVEL
  MISC
}

enum ExpenseType {
  FIXED
  VARIABLE
}

enum LeadSource {
  REFERRAL
  WEBSITE
  SOCIAL_MEDIA
  COLD_OUTREACH
  EVENT
}

enum LeadStage {
  NEW
  WARMED
  CLOSED_WON
  CLOSED_LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum ChannelType {
  PUBLIC
  PRIVATE
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum ContentCategory {
  SOCIAL_POST
  REEL
  VIDEO
  AD_CREATIVE
  BANNER
  THUMBNAIL
  BRANDING
  OTHER
}

enum ContentStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  NEEDS_REVISION
  PUBLISHED
}

enum ProjectPhase {
  DISCOVERY
  PLANNING
  DESIGN
  DEVELOPMENT
  TESTING
  DEPLOYMENT
  MAINTENANCE
}

enum MeetingStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum OrderStatus {
  NEW
  PENDING_CONFIRMATION
  CONFIRMED
  NO_ANSWER
  CANCELLED
  REFUSED
  SHIPPED
  DELIVERED
  RETURNED
}

enum OrderPaymentStatus {
  PAID
  COD_PENDING
  REFUNDED
}

enum OrderSource {
  FACEBOOK_ADS
  TIKTOK_ADS
  GOOGLE_ADS
  ORGANIC
  WHATSAPP
  INSTAGRAM
  OTHER
}

enum CommissionType {
  FIXED_PER_ORDER
  PERCENTAGE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String
  role             Role      @default(TEAM_MEMBER)
  avatar           String?
  phone            String?
  active           Boolean   @default(true)
  suspended        Boolean   @default(false)
  isCloser         Boolean   @default(false)
  lastLogin        DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignedTasks        Task[]               @relation("AssignedTasks")
  assignedLeads        Lead[]               @relation("AssignedLeads")
  activityLogs         ActivityLog[]
  channelMemberships   ChannelMember[]
  sentMessages         ChatMessage[]        @relation("SentMessages")
  messageReactions     MessageReaction[]
  conversationsA       Conversation[]       @relation("ConversationUserA")
  conversationsB       Conversation[]       @relation("ConversationUserB")
  onlineStatus         Boolean              @default(false)
  lastSeen             DateTime?
  postedUpdates        ProjectUpdate[]      @relation("PostedUpdates")
  uploadedContent      ContentDelivery[]    @relation("UploadedContent")
  adminAvailabilities  AdminAvailability[]  @relation("AdminAvailabilityUser")
  blockedDates         BlockedDate[]        @relation("BlockedDateUser")
  adminMeetings        Meeting[]            @relation("AdminMeetings")
  closerOrders         CrmOrder[]           @relation("CloserOrders")
  commissionRules      CommissionRule[]     @relation("CloserRules")
  commissionRecords    CloserCommissionRecord[] @relation("CloserRecords")
  clientAssignments    ClientCloser[]       @relation("CloserClients")

  @@map("users")
}

model Client {
  id                String           @id @default(cuid())
  name              String
  service           String
  monthlyFee        Float
  billingFrequency  BillingFrequency @default(MONTHLY)
  status            ClientStatus     @default(ACTIVE)
  startDate         DateTime
  website           String?
  googleDriveLink   String?
  notes             String?
  contactPerson     String
  email             String
  phone             String?
  country           String?
  preferredCurrency String           @default("MAD") @map("preferred_currency")
  archived          Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  payments          Payment[]
  tasks             Task[]
  activityLogs      ActivityLog[]
  portalUser        ClientPortalUser?
  projectUpdates    ProjectUpdate[]
  contentDeliveries ContentDelivery[]
  kpiConfig         ClientKpiConfig?
  meetings          Meeting[]
  crmOrders         CrmOrder[]
  crmCustomers      CrmCustomer[]
  shopifyConfigs    ShopifyConfig[]
  commissionRules   CommissionRule[]
  assignedClosers   ClientCloser[]
  costs             ClientCost[]

  @@map("clients")
}

model ClientCost {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, date, createdAt])
  @@map("client_costs")
}

model Payment {
  id            String        @id @default(cuid())
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount        Float
  date          DateTime
  method        PaymentMethod @default(BANK_TRANSFER)
  invoiceNumber String?
  status        PaymentStatus @default(PENDING)
  notes         String?
  pdfUrl        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Expense {
  id            String          @id @default(cuid())
  name          String
  category      ExpenseCategory
  type          ExpenseType
  amount        Float
  date          DateTime
  method        PaymentMethod?
  notes         String?
  recurring     Boolean         @default(false)
  paymentStatus String          @default("PENDING")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("expenses")
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  company       String?
  email         String
  phone         String?
  service       String
  expectedValue Float?
  source        LeadSource
  stage         LeadStage  @default(NEW)
  assignedToId  String?
  assignedTo    User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  notes         String?
  followUpDate  DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  activities LeadActivity[]

  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  note      String
  createdAt DateTime @default(now())

  @@map("lead_activities")
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  assignedToId String?
  assignedTo   User?      @relation("AssignedTasks", fields: [assignedToId], references: [id])
  clientId     String?
  client       Client?    @relation(fields: [clientId], references: [id])
  priority     Priority   @default(MEDIUM)
  dueDate      DateTime?
  status       TaskStatus @default(TODO)
  tags         String[]   @default([])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("tasks")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  module    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model CompanyService {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_services")
}

// ─── Chat Models ──────────────────────────────────────────────────────────────

model Channel {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String?
  type        ChannelType @default(PUBLIC)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  members  ChannelMember[]
  messages ChatMessage[]   @relation("ChannelMessages")

  @@map("channels")
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([channelId, userId])
  @@map("channel_members")
}

model Conversation {
  id        String   @id @default(cuid())
  userAId   String
  userA     User     @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     User     @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[] @relation("ConversationMessages")

  @@unique([userAId, userBId])
  @@map("conversations")
}

model ChatMessage {
  id             String      @id @default(cuid())
  senderId       String
  sender         User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  channelId      String?
  channel        Channel?    @relation("ChannelMessages", fields: [channelId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  content        String
  type           MessageType @default(TEXT)
  fileUrl        String?
  fileName       String?
  replyToId      String?
  replyTo        ChatMessage? @relation("Replies", fields: [replyToId], references: [id])
  replies        ChatMessage[] @relation("Replies")
  edited         Boolean     @default(false)
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  reactions MessageReaction[]

  @@map("chat_messages")
}

model MessageReaction {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

// ─── Client Portal Models ─────────────────────────────────────────────────────

model ClientPortalUser {
  id               String               @id @default(cuid())
  email            String               @unique
  password         String
  clientId         String               @unique
  client           Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name             String
  avatar           String?
  active           Boolean              @default(true)
  lastLogin        DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  notifications    ClientNotification[]

  @@map("client_portal_users")
}

model ProjectUpdate {
  id         String        @id @default(cuid())
  clientId   String
  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title      String
  content    String
  phase      ProjectPhase?
  imageUrl   String?
  fileUrl    String?
  postedById String
  postedBy   User          @relation("PostedUpdates", fields: [postedById], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  comments   UpdateComment[]

  @@map("project_updates")
}

model UpdateComment {
  id         String        @id @default(cuid())
  updateId   String
  update     ProjectUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)
  content    String
  isClient   Boolean       @default(false)
  authorName String
  authorId   String?
  createdAt  DateTime      @default(now())

  @@map("update_comments")
}

model ContentDelivery {
  id           String          @id @default(cuid())
  clientId     String
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  fileUrl      String?
  previewUrl   String?
  externalLink String?
  category     ContentCategory @default(OTHER)
  status       ContentStatus   @default(DRAFT)
  uploadedById String
  uploadedBy   User            @relation("UploadedContent", fields: [uploadedById], references: [id])
  clientComment String?
  revisionNote  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("content_deliveries")
}

model ClientNotification {
  id                 String           @id @default(cuid())
  clientPortalUserId String
  clientPortalUser   ClientPortalUser @relation(fields: [clientPortalUserId], references: [id], onDelete: Cascade)
  title              String
  message            String
  type               String           @default("info")
  read               Boolean          @default(false)
  link               String?
  createdAt          DateTime         @default(now())

  @@map("client_notifications")
}

model ClientKpiConfig {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  metaToken       String?
  metaAdAccountId String?
  updatedAt       DateTime @updatedAt

  @@map("client_kpi_configs")
}

model ExchangeRate {
  id             String   @id @default(cuid())
  baseCurrency   String   @map("base_currency")
  targetCurrency String   @map("target_currency")
  rate           Float
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([baseCurrency, targetCurrency])
  @@map("exchange_rates")
}

// ─── Meeting Models ───────────────────────────────────────────────────────────

model MeetingType {
  id          String    @id @default(cuid())
  name        String
  duration    Int
  description String?
  color       String    @default("#f59e0b")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  meetings Meeting[]

  @@map("meeting_types")
}

model AdminAvailability {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("AdminAvailabilityUser", fields: [adminId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String   @default("Africa/Casablanca")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adminId, dayOfWeek])
  @@map("admin_availability")
}

model BlockedDate {
  id          String   @id @default(cuid())
  adminId     String
  admin       User     @relation("BlockedDateUser", fields: [adminId], references: [id], onDelete: Cascade)
  blockedDate DateTime
  reason      String?
  createdAt   DateTime @default(now())

  @@map("blocked_dates")
}

model Meeting {
  id                   String        @id @default(cuid())
  clientId             String?
  client               Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  adminId              String
  admin                User          @relation("AdminMeetings", fields: [adminId], references: [id])
  meetingTypeId        String?
  meetingType          MeetingType?  @relation(fields: [meetingTypeId], references: [id])
  title                String
  description          String?
  meetingLink          String?
  status               MeetingStatus @default(SCHEDULED)
  startTime            DateTime
  endTime              DateTime
  timezone             String        @default("Africa/Casablanca")
  notes                String?
  internalNotes        String?
  cancelReason         String?
  bookedByPortalUserId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@map("meetings")
}

// ─── CRM Models ───────────────────────────────────────────────────────────────

model CrmCustomer {
  id          String      @id @default(cuid())
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  city        String?
  address     String?
  notes       String?
  totalSpend  Float       @default(0)
  orderCount  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders CrmOrder[]

  @@map("crm_customers")
}

model CrmOrder {
  id               String             @id @default(cuid())
  clientId         String
  client           Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  closerId         String?
  closer           User?              @relation("CloserOrders", fields: [closerId], references: [id])
  customerId       String?
  customer         CrmCustomer?       @relation(fields: [customerId], references: [id])
  shopifyOrderId   String?
  shopifyStore     String?

  customerName     String
  customerPhone    String?
  customerCity     String?
  productName      String
  quantity         Int                @default(1)
  orderAmount      Float
  productCost      Float              @default(0)
  shippingCost     Float              @default(0)
  adCost           Float              @default(0)
  closerCommission Float              @default(0)
  netProfit        Float              @default(0)

  status           OrderStatus        @default(NEW)
  paymentStatus    OrderPaymentStatus @default(COD_PENDING)
  source           OrderSource        @default(OTHER)

  notes            String?
  closerNotes      String?
  confirmedAt      DateTime?

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  commissionRecords CloserCommissionRecord[]

  @@map("crm_orders")
}

model ShopifyConfig {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  storeName   String
  storeUrl    String
  accessToken String
  active      Boolean  @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("shopify_configs")
}

model CommissionRule {
  id          String         @id @default(cuid())
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  closerId    String?
  closer      User?          @relation("CloserRules", fields: [closerId], references: [id])
  name        String
  type        CommissionType @default(FIXED_PER_ORDER)
  fixedAmount Float?
  percentage  Float?
  active      Boolean        @default(true)
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("commission_rules")
}

model CloserCommissionRecord {
  id        String   @id @default(cuid())
  closerId  String
  closer    User     @relation("CloserRecords", fields: [closerId], references: [id])
  orderId   String
  order     CrmOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Float
  paid      Boolean  @default(false)
  paidAt    DateTime?
  createdAt DateTime @default(now())

  @@map("closer_commission_records")
}

model ClientCloser {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("CloserClients", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([clientId, userId])
  @@map("client_closers")
}
